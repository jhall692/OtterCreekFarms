@page "/settings"

<PageTitle>Settings — Otter Creek Farms</PageTitle>

<div class="page-header">
    <div class="header-eyebrow">Configuration</div>
    <div class="header-title">Settings</div>
</div>

<div class="page-body">
    <a href="/settings/feed" class="settings-card">
        <div class="settings-card-icon">🌾</div>
        <div class="settings-card-body">
            <div class="settings-card-title">Feed &amp; Seasonality</div>
            <div class="settings-card-sub">Bulk feed cost, pasture months, winter multiplier</div>
        </div>
        <div class="settings-card-arrow">›</div>
    </a>
    <a href="/settings/revenue" class="settings-card">
        <div class="settings-card-icon">💵</div>
        <div class="settings-card-body">
            <div class="settings-card-title">Revenue &amp; Pricing</div>
            <div class="settings-card-sub">Whole/half price, retail cut prices</div>
        </div>
        <div class="settings-card-arrow">›</div>
    </a>
    <a href="/settings/pigcost" class="settings-card">
        <div class="settings-card-icon">🐷</div>
        <div class="settings-card-body">
            <div class="settings-card-title">Pig Cost Defaults</div>
            <div class="settings-card-sub">Vet, vaccine, bedding, misc per pig</div>
        </div>
        <div class="settings-card-arrow">›</div>
    </a>
    <a href="/settings/butcher" class="settings-card">
        <div class="settings-card-icon">🔪</div>
        <div class="settings-card-body">
            <div class="settings-card-title">Butcher Profiles</div>
            <div class="settings-card-sub">Processing fees by location</div>
        </div>
        <div class="settings-card-arrow">›</div>
    </a>
</div>
